{
  "name": "vc-biz",
  "version": "1.0.0",
  "description": "VC business UI components built on vc-design and Ant Design.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css",
    "*.css"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-store-logo-map.mjs",
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "antd": ">=5.0.0 <6.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vc-design": ">=1.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "antd": "^5.22.0",
    "jsdom": "^26.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vc-design": "file:../..",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "rc-motion": "^2.9.5",
    "use-context-selector": "^2.0.0",
    "xlsx": "^0.18.5"
  }
}
